# Discord 봇 토큰 (Developer Portal > Bot > Reset Token)
DISCORD_TOKEN=여기에_봇_토큰_입력

# 봇이 동작할 단일 서버(길드) ID. 디스코드 개발자 모드 활성화 후 서버 우클릭 > "서버 ID 복사"
GUILD_ID=000000000000000000

# PostgreSQL 연결 문자열 (Neon 등). 끝에 ?sslmode=require 권장
# 예: postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# 비활성 판정 기준 일수 (기본 30)
INACTIVE_DAYS=30

# 자동 비활성 보고 주기(시간). 기본 168 = 매주
REPORT_INTERVAL_HOURS=168

# (선택) AI 대화(/ai, /대화)용 Google Gemini API 키. https://aistudio.google.com/apikey 에서 무료 발급
# 비워두면 봇은 정상 동작하되 "하루야" AI 대화만 비활성화됩니다.
GEMINI_API_KEY=

# AI 사용자별 쿨다운(초). 1인당 이 시간에 한 번만 호출 (기본 10)
AI_COOLDOWN_SECONDS=10

# 메시지에 랜덤 이모지를 달 확률 (0~1, 기본 0.05 = 5%). 0 이면 비활성
REACT_CHANCE=0.05

# (선택) Groq 폴백용 키. Gemini 한도 초과 시 자동 전환. https://console.groq.com/keys (무료)
GROQ_API_KEY=
# Groq 모델 (기본 llama-3.3-70b-versatile). 모델이 폐기되면 콘솔에서 사용 가능 모델로 변경
GROQ_MODEL=llama-3.3-70b-versatile

# 일반 채팅에 봇이 임의로 AI 답장할 확률 (0~1, 기본 0.02 = 2%). 0 이면 비활성. (쿼터 보호 위해 낮게)
REPLY_CHANCE=0.02

# 채널별 대화 맥락 기억 턴 수(질문/답 쌍). 기본 8. DB에 저장돼 재시작에도 유지. 클수록 토큰↑
CHAT_HISTORY_TURNS=8

# 로그 레벨 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
