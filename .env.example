# Discord 봇 토큰 (Developer Portal > Bot > Reset Token)
DISCORD_TOKEN=여기에_봇_토큰_입력

# 봇이 동작할 단일 서버(길드) ID. 디스코드 개발자 모드 활성화 후 서버 우클릭 > "서버 ID 복사"
GUILD_ID=000000000000000000

# PostgreSQL 연결 문자열 (Neon 등). 끝에 ?sslmode=require 권장
# 예: postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# 비활성 판정 기준 일수 (기본 30)
INACTIVE_DAYS=30

# 자동 비활성 보고 주기(시간). 기본 168 = 매주
REPORT_INTERVAL_HOURS=168

# 로그 레벨 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
